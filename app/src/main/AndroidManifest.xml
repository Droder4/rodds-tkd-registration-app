<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.roddstkd.registrationapp">

    <!-- Internet permission required for Google Apps Script API -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:label="Rodds TKD"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.RoddsTKDRegistrationApp">

        <!-- Main screen -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Student list / admin -->
        <activity
            android:name=".RegistrationListActivity"
            android:exported="false" />

        <!-- Attendance tracking -->
        <activity
            android:name=".AttendanceActivity"
            android:exported="false" />

        <!-- Belt testing management -->
        <activity
            android:name=".BeltTestingActivity"
            android:exported="false" />

        <!-- Email / communication tools -->
        <activity
            android:name=".CommunicationsActivity"
            android:exported="false" />

    </application>

</manifest>
