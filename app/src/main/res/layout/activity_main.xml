<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Rodd's Taekwondo"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingBottom="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#F3F6FB"
            android:padding="14dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tvTotalStudents"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Total Students: 0"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvCornwallCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cornwall: 0"
                android:layout_marginTop="6dp" />

            <TextView
                android:id="@+id/tvMontagueCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Montague: 0"
                android:layout_marginTop="6dp" />

            <TextView
                android:id="@+id/tvPendingEmails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pending Welcome Emails: 0"
                android:layout_marginTop="6dp" />

            <TextView
                android:id="@+id/tvUnpaidCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Unpaid Students: 0"
                android:layout_marginTop="6dp" />

            <TextView
                android:id="@+id/tvBeltInviteCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Belt Invites Ready: 0"
                android:layout_marginTop="6dp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnViewRegistrations"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="View Registrations"
            android:layout_marginBottom="10dp" />

        <Button
            android:id="@+id/btnCornwallRoster"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="View Cornwall Roster"
            android:layout_marginBottom="10dp" />

        <Button
            android:id="@+id/btnMontagueRoster"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="View Montague Roster"
            android:layout_marginBottom="10dp" />

        <Button
            android:id="@+id/btnCommunications"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Communications" />

    </LinearLayout>
</ScrollView>
