<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp">

    <Spinner
        android:id="@+id/spinnerBeltClub"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <Spinner
        android:id="@+id/spinnerBeltClass"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp" />

    <Button
        android:id="@+id/btnLoadBeltStudents"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Load Belt Testing List"
        android:layout_marginTop="10dp" />

    <Button
        android:id="@+id/btnSendBeltInvitesFromScreen"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Send Belt Test Invites"
        android:layout_marginTop="10dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewBeltTesting"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="12dp" />
</LinearLayout>
